{
  "texture": {
    "in": "skyhighocs:aidan/aidan_stelar_visualizer_lights_<VISUALIZER>",
    "transform": [
      {
        "operation": "XOR",
        "supply": "skyhighocs:xor/wave_change_<TIMER>"
      }
    ],
    "out": "skyhighocs:generated/aidan_stelar_visualizer_lights_<VISUALIZER>_<TIMER>"
  },
  "getters": {
    "VISUALIZER": {
      "key": "entity.getData('skyhighocs:dyn/visualizer_toggle') ? 'down' : 'up'",
      "values": ["up", "down"]
    },
    "TIMER": {
      "key": "Math.min(Math.max(Math.ceil(80 * entity.getInterpolatedData('skyhighocs:dyn/wave_changing_timer')), 16), 31) | 0",
      "values": {
        "min": 16,
        "max": 31
      }
    }
  },
  "isDynamic": true
}